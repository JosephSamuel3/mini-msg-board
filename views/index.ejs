<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini message board</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include("navbar") %>
    <div class="content">
        <h1>Mini Message board</h1>
        <ul class="messages">
            <% messages.forEach(message => { %>
                <li>
                    <strong><%= message.user %></strong>: <%= message.text %> <em>(<%= message.added.toLocaleString() %>)</em>
                </li>
            <% }) %>
        </ul>
    </div>
</body>
</html>